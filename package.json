{
  "name": "minopencil",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native vector prototyping design tool — Forked from OpenPencil.",
  "author": {
    "name": "MinoPencil contributors"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "main": "out/desktop/main.cjs",
  "scripts": {
    "dev": "cd apps/web && npx vite",
    "build": "cd apps/web && npx vite build",
    "preview": "cd apps/web && npx vite preview",
    "test": "npx vitest run --passWithNoTests",
    "electron:dev": "npx tsx apps/desktop/dev.ts",
    "electron:build": "npm run build && npx electron-builder --config apps/desktop/electron-builder.yml",
    "generate": "npx tsx -e \"import { compileSkills } from './packages/pen-ai-skills/vite-plugin-skills'; compileSkills('./packages/pen-ai-skills')\"",
    "lint": "echo 'lint not configured'",
    "format": "echo 'format not configured'"
  },
  "dependencies": {
    "@iconify-json/feather": "^1.2.1",
    "@iconify-json/lucide": "^1.2.93",
    "@iconify-json/simple-icons": "^1.2.71",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "1.168.1",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.2",
    "@tanstack/router-plugin": "1.167.1",
    "canvaskit-wasm": "^0.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "h3": "^2.0.1-rc.18",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "isomorphic-git": "^1.37.5",
    "kiwi-schema": "^0.5.0",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.6",
    "nitro": "npm:nitro-nightly@latest",
    "paper": "^0.12.18",
    "rbush": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "sshpk": "^1.18.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "uzip": "^0.20201231.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@tanstack/devtools-vite": "0.6.0",
    "@types/node": "^22.10.2",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sshpk": "^1.17.4",
    "@types/uzip": "^0.20201231.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5"
  }
}
